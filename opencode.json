{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "docker",
                "exec",
                "-i",
                "flow-ledger-laravel.test-1",
                "php",
                "artisan",
                "boost:mcp"
            ]
        }
    },
    "agent": {
        "build": {
            "permission": {
                "*": "allow",
                "bash": "ask"
            }
        }
    }
}
